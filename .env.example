PORT=5000
DATABASE_URL=postgresql://localhost:5432/agence
JWT_SECRET=your_jwt_secret_here

# Plaid (sandbox)
PLAID_CLIENT_ID=your_plaid_client_id
PLAID_SECRET=your_plaid_secret
PLAID_ENV=sandbox

# Finnhub
FINNHUB_API_KEY=your_finnhub_api_key

# Alpaca (paper trading — never set ALPACA_PAPER=false for P3)
ALPACA_API_KEY=your_alpaca_paper_api_key
ALPACA_SECRET_KEY=your_alpaca_paper_secret_key
ALPACA_PAPER=true
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key

# Google OAuth — for "Sign in with Google" (https://console.cloud.google.com → APIs & Services → Credentials)
GOOGLE_CLIENT_ID=your-google-oauth-client-id
REACT_APP_GOOGLE_CLIENT_ID=your-google-oauth-client-id
